# === Database (PostgreSQL via Supabase) ===
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# === NextAuth ===
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-secret-with-at-least-32-characters"

# === Redis (rate limiting — optional, falls back to in-memory if unset) ===
# REDIS_URL="redis://localhost:6379"

# === Riot Games API ===
RIOT_API_KEY="RGAPI-xxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
RIOT_TOKEN_ENCRYPTION_KEY="generate-a-32-byte-base64-encryption-key"

# === Stripe ===
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_PRICE_PRO_MONTHLY="price_xxx"

# === AI Provider (OPENAI, CLAUDE, or GEMINI) ===
AI_PROVIDER="OPENAI"

# === OpenAI ===
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"

# === Other LLM API Keys (optional — set when connecting a provider) ===
# CLAUDE_API_KEY="sk-ant-..."
# GEMINI_API_KEY="..."

# === Internal Jobs ===
INTERNAL_JOB_SECRET="generate-a-secure-internal-job-secret"

# === Public URL (used for OG images, canonical URLs) ===
# NEXT_PUBLIC_APP_URL="https://valostats.app"

# === Download Source (ValoStats Companion installer) ===
# Options: "local", "github", "s3"
# "local" — serves from public/downloads/ (for development)
# "github" — fetches from GitHub Releases (for production)
DOWNLOAD_SOURCE=local
# GITHUB_OWNER=valostats
# GITHUB_REPO=Valostats-Companion
# GH_PAT=github_pat_...  # Optional, increases API rate limit
